{
  "manifest_version": 3,
  "name": "YouTube ASL Overlay Sync",
  "description": "Displays an ASL overlay above YouTube and syncs ASL playback with video pause/play.",
  "version": "0.1.1",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["youtube_overlay.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["asl_app/*", "asl_app/src/*", "asl_app/src/data/*"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "action": {
    "default_title": "YouTube ASL Overlay Sync"
  }
}
